rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    match /invitations/{inviteId} {
      // Anyone can read an invitation to view it
      allow read: if true;
      
      // Only authenticated users can create, and they must set themselves as the creator
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      
      // Only the original creator can edit or delete their invitation
      allow update: if request.auth != null && resource.data.creatorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;

      match /rsvps/{rsvpId} {
        // Anyone can read RSVPs for the invitation
        allow read: if true;
        
        // Anyone can submit an RSVP
        allow create: if true;
        
        // RSVPs cannot be modified or deleted directly by guests
        allow update, delete: if false;
      }
    }
  }
}
